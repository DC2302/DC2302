# Copy this file to .env and fill in your real values.
# NEVER commit the .env file itself — it contains secrets.

# --- Claude (Anthropic) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model used to answer callers. claude-haiku-4-5-20251001 is fast and cheap
# (good for phone latency); claude-sonnet-5 is smarter for complex questions.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Twilio ---
# From https://console.twilio.com/ — the auth token validates that webhook
# requests really come from Twilio; the account SID is also needed to SEND
# text messages (callback notifications and payment links).
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Per-client payment keys ---
# Each company's company.json names the env vars that hold ITS keys, so
# client secrets never go into the git repo. Example for CADD Truck Parking:
SQUARE_ACCESS_TOKEN_CADD=
SQUARE_LOCATION_ID_CADD=
STRIPE_SECRET_KEY_CADD=

# --- Server ---
PORT=3000

# The public HTTPS URL where this server is reachable, e.g. your
# Render/Railway/Fly.io URL, or an ngrok URL during local testing.
PUBLIC_BASE_URL=https://your-app.example.com
